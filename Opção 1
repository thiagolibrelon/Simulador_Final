<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Localiza&Co · Simulador</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

[data-theme="dark"]{
  --green:#00C853;--green-l:#69F0AE;--green-bg:#00C85315;--green-bd:#00C85340;
  --bg:#080C0A;--s1:#0F1510;--s2:#131D14;--s3:#182218;
  --bd:#1C2A1C;--bd2:#223222;
  --text:#E4FFE8;--muted:#5E8A6A;--muted2:#3A5442;
  --red:#FF3D5A;--red-bg:#FF3D5A12;--red-bd:#FF3D5A35;
  --amber:#FFB300;--amber-bg:#FFB30015;--amber-bd:#FFB30040;
  --topbar-a:#003018;--topbar-b:#004D22;
  --input-bg:#0F1510;--shadow:0 2px 16px #00000060;
  --pill-bg:#0F1510;
}
[data-theme="light"]{
  --green:#007A2A;--green-l:#005A1E;--green-bg:#007A2A0A;--green-bd:#007A2A25;
  --bg:#EFF4F0;--s1:#FFFFFF;--s2:#F3F8F4;--s3:#E8F2EA;
  --bd:#C8DDC8;--bd2:#B5CEB5;
  --text:#091A0C;--muted:#3D6645;--muted2:#7A9E80;
  --red:#C8002A;--red-bg:#C8002A0A;--red-bd:#C8002A25;
  --amber:#9A6000;--amber-bg:#9A600010;--amber-bd:#9A600030;
  --topbar-a:#003D18;--topbar-b:#005A22;
  --input-bg:#FFFFFF;--shadow:0 2px 12px #00000015;
  --pill-bg:#E8F2EA;
}

*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;min-height:100vh;transition:background .3s,color .3s}

/* ── TOPBAR ── */
.topbar{
  background:linear-gradient(135deg,var(--topbar-a),var(--topbar-b));
  border-bottom:1px solid rgba(0,200,80,.2);
  padding:0 24px;height:54px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:200;
}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:32px;height:32px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900;color:#fff;flex-shrink:0}
.logo-name{font-size:15px;font-weight:800;color:#fff;letter-spacing:-.2px}
.logo-name em{color:#7EFFA8;font-style:normal}
.logo-sub{font-size:10px;color:#7FD49A;font-weight:500}
.topbar-r{display:flex;align-items:center;gap:8px}
.p-switcher{display:flex;background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:3px;gap:2px}
.p-btn{padding:4px 14px;border:none;background:transparent;color:rgba(255,255,255,.6);font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;border-radius:14px;transition:all .2s;white-space:nowrap}
.p-btn.active{background:var(--green);color:#fff}
.tb-btn{height:30px;padding:0 12px;border:1px solid rgba(255,255,255,.15);border-radius:15px;background:rgba(255,255,255,.1);color:rgba(255,255,255,.8);font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:5px;transition:.2s}
.tb-btn:hover{background:rgba(255,255,255,.2)}
.theme-btn{width:46px;height:26px;border-radius:13px;background:rgba(0,0,0,.3);border:1px solid rgba(255,255,255,.15);cursor:pointer;display:flex;align-items:center;padding:0 3px;flex-shrink:0}
.tt-k{width:20px;height:20px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;transition:transform .25s;box-shadow:0 1px 3px #00000030}
[data-theme="light"] .tt-k{transform:translateX(20px)}

/* ── TABS ── */
.tabs-bar{display:flex;gap:2px;padding:12px 20px 0;border-bottom:1px solid var(--bd);background:var(--s1);position:sticky;top:54px;z-index:100;transition:background .3s,border-color .3s}
.tab{padding:7px 16px;border:1px solid transparent;border-bottom:none;border-radius:7px 7px 0 0;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;background:transparent;font-family:inherit}
.tab:hover{color:var(--text);background:var(--s2)}
.tab.active{color:var(--green);background:var(--green-bg);border-color:var(--green-bd);border-bottom-color:var(--s1)}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* ── WIZARD LAYOUT ── */
.wizard-wrap{display:grid;grid-template-columns:1fr 380px;min-height:calc(100vh - 100px);align-items:start}

/* ── LEFT PANE ── */
.left-pane{padding:28px 32px;border-right:1px solid var(--bd)}

/* progress */
.progress-bar{display:flex;align-items:center;gap:0;margin-bottom:28px}
.prog-step{display:flex;align-items:center;flex:1}
.prog-dot{width:28px;height:28px;border-radius:50%;border:2px solid var(--bd2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--muted);transition:all .3s;flex-shrink:0;cursor:pointer;background:var(--s1)}
.prog-dot.done{background:var(--green);border-color:var(--green);color:#fff}
.prog-dot.active{background:var(--green-bg);border-color:var(--green);color:var(--green)}
.prog-line{flex:1;height:2px;background:var(--bd2);transition:background .3s}
.prog-line.done{background:var(--green)}
.prog-label{font-size:10px;color:var(--muted);margin-top:5px;text-align:center;font-weight:500;white-space:nowrap}
.prog-step-wrap{display:flex;flex-direction:column;align-items:center;gap:0}

/* step panel */
.step-panel{display:none}
.step-panel.active{display:block}
.step-eyebrow{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--green);margin-bottom:6px}
.step-title{font-size:22px;font-weight:800;color:var(--text);margin-bottom:6px;letter-spacing:-.5px;line-height:1.2}
.step-subtitle{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.6}

/* microcopy box */
.microcopy{background:var(--amber-bg);border:1px solid var(--amber-bd);border-radius:10px;padding:12px 16px;margin-bottom:20px;font-size:12px;color:var(--amber);line-height:1.6}
.microcopy strong{color:var(--amber)}
.microcopy.green-copy{background:var(--green-bg);border-color:var(--green-bd);color:var(--green)}

/* fields */
.field-group{margin-bottom:20px}
.field-group:last-child{margin-bottom:0}
.f-label{font-size:12px;font-weight:600;color:var(--muted);margin-bottom:6px;display:flex;align-items:center;gap:5px}
.tip{width:14px;height:14px;border-radius:50%;background:var(--s3);border:1px solid var(--bd2);display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--muted2);cursor:help;position:relative;flex-shrink:0}
.tip:hover::after{content:attr(data-tip);position:absolute;left:18px;top:-4px;background:var(--s2);border:1px solid var(--bd2);border-radius:8px;padding:8px 12px;font-size:11px;font-weight:400;color:var(--text);z-index:300;min-width:200px;max-width:260px;white-space:normal;line-height:1.4;box-shadow:var(--shadow)}
.input-row{display:grid;grid-template-columns:1fr 130px;align-items:center;gap:10px}
.input-wrap{display:flex;align-items:center;background:var(--input-bg);border:1px solid var(--bd2);border-radius:8px;overflow:hidden;transition:border-color .2s}
.input-wrap:focus-within{border-color:var(--green)}
.input-wrap input,.input-wrap select{background:transparent;border:none;outline:none;padding:8px 10px;color:var(--text);font-family:inherit;font-size:13px;font-weight:500;width:100%;min-width:0}
.input-unit{padding:0 10px 0 2px;font-size:11px;font-weight:600;color:var(--muted2);white-space:nowrap;flex-shrink:0}
select option{background:var(--s2);color:var(--text)}

/* sliders */
.slider-row{margin-bottom:14px}
.slider-head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px}
.slider-name{font-size:12px;font-weight:600;color:var(--muted)}
.slider-val{font-size:14px;font-weight:800;color:var(--green)}
input[type=range]{width:100%;accent-color:var(--green);height:6px;cursor:pointer}
.slider-hint{font-size:10px;color:var(--muted2);margin-top:3px}

/* regime selector */
.regime-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.regime-card{border:2px solid var(--bd2);border-radius:12px;padding:16px;cursor:pointer;transition:all .25s;background:var(--s1)}
.regime-card:hover{border-color:var(--green-bd)}
.regime-card.selected{border-color:var(--green);background:var(--green-bg)}
.regime-icon{font-size:24px;margin-bottom:8px}
.regime-name{font-size:14px;font-weight:700;color:var(--text);margin-bottom:4px}
.regime-desc{font-size:11px;color:var(--muted);line-height:1.5}
.regime-badge{display:inline-block;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;margin-top:6px}
.badge-real{background:var(--green-bg);color:var(--green);border:1px solid var(--green-bd)}
.badge-pres{background:var(--amber-bg);color:var(--amber);border:1px solid var(--amber-bd)}

/* credit animation */
.credit-anim{background:var(--green-bg);border:1px solid var(--green-bd);border-radius:10px;padding:14px 16px;margin-top:16px;transition:all .4s}
.credit-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:12px}
.credit-row span{color:var(--muted)}
.credit-row strong{color:var(--green);font-weight:700}
.credit-total{border-top:1px solid var(--green-bd);margin-top:8px;padding-top:8px;display:flex;justify-content:space-between}
.credit-total span{font-size:12px;font-weight:700;color:var(--text)}
.credit-total strong{font-size:16px;font-weight:900;color:var(--green-l)}

/* nav buttons */
.nav-btns{display:flex;gap:10px;margin-top:28px;padding-top:20px;border-top:1px solid var(--bd)}
.btn-back{flex:1;padding:11px;border:1px solid var(--bd2);border-radius:9px;background:transparent;color:var(--muted);font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;transition:.2s}
.btn-back:hover{border-color:var(--muted);color:var(--text)}
.btn-next{flex:2;padding:11px;border:none;border-radius:9px;background:var(--green);color:#fff;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;transition:.2s}
.btn-next:hover{opacity:.9}
.btn-next:disabled{opacity:.4;cursor:not-allowed}

/* ── RIGHT PANE — TOTALIZER ── */
.right-pane{padding:24px 20px;position:sticky;top:100px}

.totalizer-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:16px}

/* termometer */
.thermo-wrap{margin-bottom:20px}
.thermo-label{display:flex;justify-content:space-between;margin-bottom:6px}
.thermo-name{font-size:11px;font-weight:600;color:var(--muted)}
.thermo-amount{font-size:13px;font-weight:700;color:var(--text)}
.thermo-track{height:10px;background:var(--s3);border-radius:5px;overflow:hidden;margin-bottom:3px}
.thermo-fill{height:100%;border-radius:5px;transition:width .5s cubic-bezier(.4,0,.2,1),background .4s;min-width:0}
.thermo-fill.c-acq{background:var(--amber)}
.thermo-fill.c-cap{background:#FF6B35}
.thermo-fill.c-op{background:var(--red)}
.thermo-fill.c-alg{background:var(--green)}
.thermo-hint{font-size:10px;color:var(--muted2)}

.divider{height:1px;background:var(--bd);margin:16px 0}

/* big number */
.big-num-wrap{text-align:center;margin-bottom:16px}
.big-num-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:4px}
.big-num{font-size:40px;font-weight:900;letter-spacing:-2px;line-height:1;color:var(--red);transition:color .4s}
.big-num.neutral{color:var(--muted)}
.big-num-sub{font-size:11px;color:var(--muted);margin-top:4px}

/* finalist */
.finalist{display:none;margin-top:16px}
.finalist.show{display:block}
.finalist-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:10px}
.versus{display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center;margin-bottom:12px}
.v-card{background:var(--s2);border:1px solid var(--bd2);border-radius:10px;padding:12px;text-align:center;transition:all .3s}
.v-card.winner{
  background:var(--green);
  border-color:var(--green);
}

.v-card.winner .v-name,
.v-card.winner .v-val,
.v-card.winner .v-mes{
  color:#FFFFFF;
}
.v-name{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);margin-bottom:4px}
.v-val{font-size:18px;font-weight:900;letter-spacing:-1px;color:var(--text)}
.v-mes{font-size:10px;color:var(--muted);margin-top:2px}
.vs-badge{width:30px;height:30px;border-radius:50%;border:1px solid var(--bd2);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--muted)}
.econ-pill{background:var(--green-bg);border:1px solid var(--green-bd);border-radius:10px;padding:10px 14px;text-align:center;margin-top:8px}
.econ-pill.red-pill{background:var(--red-bg);border-color:var(--red-bd)}
.ep-label{font-size:10px;color:var(--muted);margin-bottom:2px}
.ep-val{font-size:20px;font-weight:900;letter-spacing:-1px;color:var(--green-l)}
.econ-pill.red-pill .ep-val{color:var(--red)}
.ep-sub{font-size:10px;color:var(--muted);margin-top:2px}

/* memory */
.mem-toggle{display:flex;align-items:center;gap:6px;padding:9px 14px;cursor:pointer;border-top:1px solid var(--bd);background:var(--s2);font-size:11px;font-weight:600;color:var(--muted);margin-top:8px;border-radius:0 0 10px 10px}
.mem-toggle:hover{color:var(--text)}
.mem-arrow{font-size:9px;margin-left:auto}
.mem-dots{display:flex;gap:4px}
.mdot{width:8px;height:8px;border-radius:50%}
.mem-body{padding:12px 14px;font-family:'Fira Code','SF Mono',Consolas,monospace;font-size:10.5px;color:#5FD87A;white-space:pre-wrap;line-height:1.6;background:#030806;display:none;border-radius:0 0 10px 10px}
[data-theme="light"] .mem-body{background:#F0F8F2;color:#1A6B30}
.mem-body.open{display:block}

/* warning */
.warn-box{background:#1A0E00;border:1px solid #4A2800;border-radius:8px;padding:8px 12px;font-size:11px;color:#C48020;margin-top:10px;display:none}
[data-theme="light"] .warn-box{background:#FFF8EC;border-color:#E8C060;color:#7A5000}

/* PDF in right pane */
.pdf-wrap{margin-top:12px}
.pdf-btn{width:100%;padding:10px;border:none;border-radius:9px;background:var(--green);color:#fff;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;transition:.2s;display:flex;align-items:center;justify-content:center;gap:6px}
.pdf-btn:hover{opacity:.85}
[data-theme="light"] .pdf-btn{color:#003018}

/* subtotal chip */
.sub-chip{background:var(--green-bg);border:1px solid var(--green-bd);border-radius:8px;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;margin-top:12px}
.sub-chip label{font-size:11px;color:var(--muted);font-weight:500}
.sub-chip strong{font-size:13px;font-weight:800;color:var(--green)}

/* mini chips */
.mini3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-top:10px}
.mini2{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:10px}
.chip{background:var(--s2);border:1px solid var(--bd);border-radius:7px;padding:7px 8px;text-align:center}
.chip-l{font-size:10px;color:var(--muted);margin-bottom:1px}
.chip-v{font-size:12px;font-weight:700;color:var(--text)}
.chip-v.g{color:var(--green)}.chip-v.r{color:var(--red)}.chip-v.a{color:var(--amber)}

/* glossary */
.gloss-page{padding:20px;max-width:1100px;margin:0 auto}
.gloss-intro{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.7}
.gloss-section{margin-bottom:28px}
.gloss-stitle{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;color:var(--green);margin-bottom:12px;display:flex;align-items:center;gap:8px}
.gloss-stitle::after{content:'';flex:1;height:1px;background:var(--bd2)}
.gloss-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:10px}
.gcard{background:var(--s1);border:1px solid var(--bd);border-radius:10px;padding:13px 15px;transition:border-color .2s}
.gcard:hover{border-color:var(--green-bd)}
.gcard-h{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.gcard-icon{font-size:16px;flex-shrink:0}
.gcard-term{font-size:13px;font-weight:700;color:var(--text)}
.gcard-tag{font-size:10px;font-weight:600;color:var(--green);background:var(--green-bg);border:1px solid var(--green-bd);border-radius:10px;padding:2px 7px;margin-left:auto;white-space:nowrap}
.gcard-def{font-size:12px;color:var(--muted);line-height:1.6}
.gcard-form{margin-top:7px;background:var(--s2);border-left:3px solid var(--green-bd);padding:5px 9px;font-family:'Fira Code',Consolas,monospace;font-size:11px;color:var(--green);line-height:1.6;border-radius:0 5px 5px 0}
[data-theme="light"] .gcard-form{color:#006B20}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:2px}

@media(max-width:860px){
  .wizard-wrap{grid-template-columns:1fr}
  .right-pane{position:static;border-top:1px solid var(--bd)}
  .left-pane{border-right:none}
}
</style>
</head>
<body>

<header class="topbar">
  <div class="logo">
    <div class="logo-mark">L&</div>
    <div>
      <div class="logo-name">Localiza<em>&amp;Co</em></div>
      <div class="logo-sub">Simulador de Frota</div>
    </div>
  </div>
  <div class="topbar-r">
    <div class="p-switcher">
      <button class="p-btn" id="btnPresumido" data-profile="presumido">Lucro Presumido</button>
      <button class="p-btn active" id="btnReal" data-profile="real">Lucro Real</button>
    </div>
    <button class="tb-btn" onclick="exportPDF()">📄 PDF</button>
    <div class="theme-btn" id="themeBtn"><div class="tt-k" id="ttK">🌙</div></div>
  </div>
</header>

<div class="tabs-bar">
  <button class="tab active" id="tabSim" onclick="switchTab('sim')">📊 Simulador</button>
  <button class="tab" id="tabGloss" onclick="switchTab('gloss')">📖 Glossário</button>
</div>

<!-- ═══ TAB SIMULADOR ═══ -->
<div class="tab-panel active" id="panelSim">
<div class="wizard-wrap">

  <!-- ── LEFT PANE ── -->
  <div class="left-pane">

    <!-- PROGRESS -->
    <div class="progress-bar">
      <div class="prog-step-wrap">
        <div class="prog-dot active" id="pd0" onclick="goStep(0)">1</div>
        <div class="prog-label">Compra</div>
      </div>
      <div class="prog-step"><div class="prog-line" id="pl0"></div></div>
      <div class="prog-step-wrap">
        <div class="prog-dot" id="pd1" onclick="goStep(1)">2</div>
        <div class="prog-label">Capital</div>
      </div>
      <div class="prog-step"><div class="prog-line" id="pl1"></div></div>
      <div class="prog-step-wrap">
        <div class="prog-dot" id="pd2" onclick="goStep(2)">3</div>
        <div class="prog-label">Operação</div>
      </div>
      <div class="prog-step"><div class="prog-line" id="pl2"></div></div>
      <div class="prog-step-wrap">
        <div class="prog-dot" id="pd3" onclick="goStep(3)">4</div>
        <div class="prog-label">Fiscal</div>
      </div>
    </div>

    <!-- ── STEP 1: Aquisição do Veículo ── -->
    <div class="step-panel active" id="step0">
      <div class="step-eyebrow">Passo 1 de 4</div>
      <div class="step-title">Aquisição do Veículo</div>
      <div class="step-subtitle">Nesta etapa avaliamos o investimento inicial necessário para aquisição do veículo, considerando preço de compra, descontos negociados e desembolso imediato de caixa.</div>

      <div class="field-group">
        <div class="f-label">Preço de tabela do veículo</div>
        <div class="input-row">
          <div class="input-wrap"><div class="input-unit">R$</div><input id="valorVeiculoBruto" type="number" value="85000" step="1000" oninput="calc()"/></div>
          <div></div>
        </div>
      </div>

      <div class="field-group">
        <div class="f-label">Desconto negociado <span class="tip" data-tip="Percentual obtido na negociação da compra. Quanto maior, menor o valor final do veículo.">?</span></div>
        <div class="input-row">
          <div class="input-wrap"><input id="descontoPct" type="number" value="10" step="0.5" oninput="calc()"/><div class="input-unit">%</div></div>
          <div class="chip" style="text-align:center"><div class="chip-l">Economia</div><div class="chip-v g" id="outDesconto">R$ 0</div></div>
