/* ── CALC ── */
function calc(){
  const vBruto=n("valorVeiculoBruto"),desc=vBruto*pc(n("descontoPct")),vV=vBruto-desc;
  const entr=vV*pc(n("entradaPct")),fin=Math.max(0,vV-entr);
  const np=n("parcelas"),jm=pc(n("jurosMensalPct")),parc=pmt(fin,jm,np);
  const totP=parc*np,jTot=Math.max(0,totP-fin);
  const gParc=np<=12?totP:parc*12,saldo=np<=12?0:Math.max(0,totP-gParc);
  const baseOportunidade=entr+gParc,opor=baseOportunidade*pc(n("oportunidadePct")),aqAno=entr+gParc+opor;
  const manut=vV*pc(n("manutencaoPct")),seg=vV*pc(n("seguroPct"));
  const ipva=vV*pc(Number(el("estado").value)),lic=vV*pc(n("licenciamentoPct"));
  const parad=n("indisponibilidadeAno"),admF=n("admFrotaMensal")*12;
  const opAno=manut+seg+ipva+lic+parad+admF;
  const deprA=vV*pc(n("depreciacaoPct")),deprM=el("modoDepreciacao").value;


// Bases separadas

const basePisCofins = perfil==="real"
  ? Math.max(0, manut + deprA)
  : 0;

const baseIrpjCsll = perfil==="real"
  ? Math.max(0, admF + deprA)
  : 0;

// Créditos

const pisP = basePisCofins * pc(n("pisPropPct"));

const irjP = baseIrpjCsll * pc(n("irpjPropPct"));

const cslP = baseIrpjCsll * pc(n("csllPropPct"));

const tribP = pisP + irjP + cslP;
  
  
  revnd=Math.max(0,vV-deprA-saldo);
  const fAnoR=aqAno+opAno-tribP-revnd,fAnoPr=aqAno+opAno-revnd;
  const fAno=perfil==="real"?fAnoR:fAnoPr;
  const alqM=n("aluguelMensal"),valP=12*alqM,admA=n("admAluguel")*12;
  const atividadeFim=el("atividadeFim").value==="sim";
  const baseA=perfil==="real"?valP:0;
  const pisA=atividadeFim?baseA*pc(n("pisPropPct")):0;
  const irjA=baseA*pc(n("irpjPropPct")),cslA=baseA*pc(n("csllPropPct"));
  const tribA=pisA+irjA+cslA,totAlq=valP+admA,cAlq=valP+admA-tribA;
  const econ=fAno-cAlq,econAbs=Math.abs(econ);
  set("kpiEconomia", R(econAbs));
  const venc=econ>50?"aluguel":econ<-50?"propria":"empate";
  const maxB=Math.max(aqAno,opAno,tribP,revnd,totAlq,tribA,1);

  el("tributosNote").style.display=perfil==="presumido"?"block":"none";

  set("outValorFinal",R(vV));set("outDesconto",R(desc));set("outEntrada",R(entr));
  set("outParcela",R2(parc));set("outJurosAno",R(jTot));set("outAquisicaoAno",R(aqAno));
  set("outOperacionalAno",R(opAno));set("outDepreciacao",R(deprA));
  set("outTributosProp",R(tribP));set("outTributosAluguel",R(tribA));
  set("outAluguelAnual",R(valP));set("outAdmAluguel",R(admA));set("outTotalAluguelBruto",R(totAlq));
  set("outPisAluguel",R(pisA));set("outIrpjAluguel",R(irjA));set("outCsllAluguel",R(cslA));
  set("outTributosAluguelTotal",R(tribA));
  set("cmpAquisicao",R(aqAno));set("cmpOperacional",R(opAno));
  set("cmpTributosProp",R(tribP));set("cmpRevenda",R(revnd));
  set("cmpFrotaAno",R(fAno));set("cmpFrotaMes",R(fAno/12));
  set("cmpAluguelBruto",R(totAlq));set("cmpTributosAluguel",R(tribA));
  set("cmpAluguelAno",R(cAlq));set("cmpAluguelMes",R(cAlq/12));
  set("kpiFrota",R(fAno));set("kpiFrotaMes",R(fAno/12));
  set("kpiAluguel",R(cAlq));set("kpiAluguelMes",R(cAlq/12));

  bar("barAquisicao",aqAno,maxB);bar("barOperacional",opAno,maxB);
  bar("barTributosProp",tribP,maxB,true);bar("barRevenda",revnd,maxB,true);
  bar("barAluguel",totAlq,maxB);bar("barTributosAluguel",tribA,maxB,true);

  const cf=el("cardFrota"),ca=el("cardAluguel"),tf=el("totalFrota"),ta=el("totalAluguel");
  const bf=el("badgeFrota"),ba=el("badgeAluguel");
  cf.className="rh-card loser";ca.className="rh-card loser";
  tf.className="comp-total";ta.className="comp-total";
  bf.className="rh-badge";ba.className="rh-badge";
  set("badgeFrota","🚗 Frota Própria");set("badgeAluguel","🔑 Aluguel");
  set("kpiFrotaSub","custo efetivo anual");set("kpiAluguelSub","custo efetivo anual");

  const banner=el("econBanner");
  if(venc==="aluguel"){
    ca.className="rh-card winner";ta.className="comp-total winner-block";
    ba.className="rh-badge win";set("badgeAluguel","🏆 Aluguel — Vencedor");
    set("kpiAluguelSub","✅ opção mais econômica");
    banner.className="econ-banner";
    set("econIcon","💡");set("econTitle","Locação mais econômica no cenário simulado");
    el("econList").innerHTML="→ Evita imobilizar capital na compra da frota\n→ Transforma CAPEX em OPEX previsível\n→ Reduz riscos de manutenção, revenda e indisponibilidade\n→ Libera a empresa para focar no negócio principal";
    set("econVal",R(econAbs));el("econVal").className="econ-val";
    set("badgeEconomia","💰 Locação mais econômica");
    set("kpiEconomiaTitle","Economia estimada com locação");
    set("kpiEconomiaSub","por ano");
  } else if(venc==="propria"){
    cf.className="rh-card winner";tf.className="comp-total winner-block";
    bf.className="rh-badge win";set("badgeFrota","🏆 Frota Própria — Vencedor");
    set("kpiFrotaSub","✅ opção mais econômica");
    banner.className="econ-banner red-banner";
    set("econIcon","🚗");set("econTitle","Frota própria mais econômica no cenário simulado");
    el("econList").innerHTML="→ Menor custo financeiro no cenário simulado\n→ Melhor aproveitamento do valor residual\n→ Menor dependência de contratos recorrentes\n→ Atenção: considere custos de gestão e manutenção";
    set("econVal",R(econAbs));el("econVal").className="econ-val red";
    set("badgeEconomia","💰 Frota própria mais econômica no cenário simulado");
    set("kpiEconomiaTitle","Diferença favorável à frota própria");
    set("kpiEconomiaSub","por ano");
  } else {
    banner.className="econ-banner";
    set("econIcon","⚖️");set("econTitle","Empate técnico");
    el("econList").innerHTML="→ Ajuste os parâmetros para avaliar sensibilidade\n→ Pequenas variações podem definir a melhor opção";
    set("econVal","R$ 0");el("econVal").className="econ-val";
    set("badgeEconomia","⚖️ Equivalência econômica");
    set("kpiEconomiaTitle","Diferença econômica");
    set("kpiEconomiaSub","empate técnico");
  }

  el("memoriaCalculo").textContent=
`Perfil: ${perfil==="real"?"Lucro Real":"Lucro Presumido"} · Depreciação: ${deprM==="contabil"?"Contábil/Fiscal":"Real/Mercado"}

Valor_Final = ${R(vBruto)} − ${R(desc)} = ${R(vV)}
Entrada     = ${R(entr)} · Financiado: ${R(fin)}
Parcela     = ${R2(parc)} × ${np}× · Juros: ${R(jTot)}
Base Oport. = ${R(entr)} + ${R(gParc)} = ${R(baseOportunidade)}
Aq.Ano      = ${R(entr)} + ${R(gParc)} + ${R(opor)} = ${R(aqAno)}

Op.Ano      = ${R(manut)}+${R(seg)}+${R(ipva)}+${R(lic)}+${R(parad)}+${R(admF)} = ${R(opAno)}
              Manut. + Seguro + IPVA + Lic. + Indisp. + Adm.
Depreciação = ${R(deprA)} · Revenda = ${R(revnd)}

Base PIS/COFINS = Manutenção + Depreciação
                = ${R(manut)} + ${R(deprA)}
                = ${R(basePisCofins)}

Base IRPJ/CSLL = Adm. Frota + Depreciação
               = ${R(admF)} + ${R(deprA)}
               = ${R(baseIrpjCsll)}

PIS/COFINS = ${R(pisP)}
IRPJ       = ${R(irjP)}
CSLL       = ${R(cslP)}

Tributos Frota = ${R(tribP)}
Tributos Aluguel = ${R(pisA)}+${R(irjA)}+${R(cslA)} = ${R(tribA)}

Frota / Ano (Real)      = ${R(fAnoR)}
Frota / Ano (Presumido) = ${R(fAnoPr)}
Aluguel / Ano           = ${R(cAlq)}

Diferença = ${R(econ)} → ${venc==="aluguel"?"ALUGUEL vence":venc==="propria"?"FROTA PRÓPRIA vence":"EMPATE"} por ${R(econAbs)}`;
}

document.querySelectorAll("input,select").forEach(i=>{i.addEventListener("input",calc);i.addEventListener("change",calc);});
document.querySelectorAll(".p-btn").forEach(b=>{
  b.addEventListener("click",()=>{
    perfil=b.dataset.profile;
    document.querySelectorAll(".p-btn").forEach(x=>x.classList.remove("active"));
    b.classList.add("active");calc();
  });
});
function updateDepreciacaoInput(){
  const isContabil=el("modoDepreciacao").value==="contabil";
  el("depreciacaoPct").readOnly=isContabil;
  if(isContabil) el("depreciacaoPct").value=20;
  else if(Number(el("depreciacaoPct").value)===20) el("depreciacaoPct").value=10;
}
el("modoDepreciacao").addEventListener("change",()=>{updateDepreciacaoInput();calc();});
updateDepreciacaoInput();
calc();
</script>
