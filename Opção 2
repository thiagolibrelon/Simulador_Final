<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Localiza&Co · Simulador de Frota</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

[data-theme="dark"]{
  --green:#00C853;--green-l:#00E676;--green-bg:#00C85312;--green-bd:#00C85330;
  --bg:#090D0B;--s1:#101710;--s2:#141F14;--s3:#1A271A;
  --bd:#1E2B1E;--bd2:#243824;
  --text:#E8FFF0;--muted:#6B9478;--muted2:#3D5A47;
  --red:#FF4060;--red-bg:#FF406012;--red-bd:#FF406030;
  --amber:#FFB300;--tip-bg:#1A2E1A;--tip-bd:#243824;
  --topbar-from:#003D18;--topbar-to:#005A22;--topbar-bd:#004D1E;
  --input-bg:#141F14;--shadow:0 2px 12px #00000040;
  --tab-active-bg:#00C85318;--tab-active-bd:#00C85350;
}
[data-theme="light"]{
  --green:#009624;--green-l:#007A1E;--green-bg:#00962408;--green-bd:#00962420;
  --bg:#F0F5F1;--s1:#FFFFFF;--s2:#F4F8F5;--s3:#EAF2EC;
  --bd:#D4E4D8;--bd2:#C0D8C6;
  --text:#0D2014;--muted:#4A7057;--muted2:#7A9E88;
  --red:#D4002A;--red-bg:#D4002A0A;--red-bd:#D4002A25;
  --amber:#C47A00;--tip-bg:#FFFFFF;--tip-bd:#C0D8C6;
  --topbar-from:#004D1E;--topbar-to:#006B2E;--topbar-bd:#005A22;
  --input-bg:#FFFFFF;--shadow:0 2px 12px #00000018;
  --tab-active-bg:#00962410;--tab-active-bd:#00962440;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:13px;line-height:1.5;transition:background .25s,color .25s}

/* ── TOPBAR ── */
.topbar{background:linear-gradient(135deg,var(--topbar-from),var(--topbar-to));border-bottom:1px solid var(--topbar-bd);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:34px;height:34px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:900;color:#fff;flex-shrink:0}
.logo-name{font-size:16px;font-weight:800;color:#fff}
.logo-name em{color:#7EFFA8;font-style:normal}
.logo-sub{font-size:11px;color:#7FD49A;font-weight:500}
.topbar-right{display:flex;align-items:center;gap:10px}
.profile-switcher{display:flex;background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.12);border-radius:20px;overflow:hidden;padding:3px;gap:3px}
.p-btn{padding:5px 16px;border:none;background:transparent;color:rgba(255,255,255,.65);font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;border-radius:16px;transition:all .2s;white-space:nowrap}
.p-btn.active{background:var(--green);color:#fff}
.theme-toggle{width:52px;height:28px;border-radius:14px;background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.18);cursor:pointer;position:relative;display:flex;align-items:center;padding:0 4px;transition:background .25s;flex-shrink:0}
.tt-knob{width:22px;height:22px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;transition:transform .25s cubic-bezier(.4,0,.2,1);box-shadow:0 1px 4px #00000030}
[data-theme="light"] .tt-knob{transform:translateX(24px)}

/* ── TABS ── */
.tabs-bar{display:flex;gap:4px;padding:16px 20px 0;border-bottom:1px solid var(--bd);background:var(--s1);position:sticky;top:56px;z-index:100;transition:background .25s,border-color .25s}
.tab{padding:9px 20px;border:1px solid transparent;border-bottom:none;border-radius:8px 8px 0 0;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;background:transparent;font-family:inherit}
.tab:hover{color:var(--text);background:var(--s2)}
.tab.active{color:var(--green);background:var(--tab-active-bg);border-color:var(--tab-active-bd);border-bottom-color:var(--s1)}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* ── PAGE ── */
.page{max-width:1280px;margin:0 auto;padding:20px 20px 40px}

/* ── HERO ── */
.result-hero{
  display:grid;
  grid-template-columns:1fr 1fr 320px;
  gap:14px;
  margin-bottom:16px;
}
.rh-card{border-radius:12px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;position:relative;overflow:hidden;transition:all .25s}
.rh-card::before{content:'';position:absolute;inset:0;opacity:.06;background:radial-gradient(circle at 80% 50%,#fff,transparent)}
.rh-card.winner{background:var(--green);border:1px solid var(--green)}
.rh-card.winner .rh-badge,
.rh-card.winner .rh-title,
.rh-card.winner .rh-value,
.rh-card.winner .rh-sub,
.rh-card.winner .rh-mes-label,
.rh-card.winner .rh-mes{color:#FFFFFF}
.rh-card.loser{background:var(--s1);border:1px solid var(--bd);box-shadow:var(--shadow)}
.rh-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(0,0,0,.08);border-radius:20px;padding:3px 10px;font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px}
.rh-badge.win{background:rgba(255,255,255,.18);color:#FFFFFF}
.rh-title{font-size:13px;font-weight:600;color:var(--muted);margin-bottom:4px}
.rh-value{font-size:36px;font-weight:900;letter-spacing:-2px;line-height:1;color:var(--text)}
.rh-sub{font-size:12px;color:var(--muted);margin-top:4px}
.rh-right{text-align:right;flex-shrink:0}
.rh-mes-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.8px}
.rh-mes{font-size:20px;font-weight:700;color:var(--text);letter-spacing:-1px}

/* ── BANNER ── */
.econ-banner {
display: none;
}
.econ-banner.red-banner{background:var(--red-bg);border-color:var(--red-bd)}
.econ-icon{font-size:28px;flex-shrink:0}
.econ-body{flex:1}
.econ-title{font-size:15px;font-weight:800;color:var(--text);margin-bottom:3px}
.econ-list{font-size:12px;color:var(--muted);line-height:1.9}
.econ-value-block{text-align:right;flex-shrink:0}
.econ-val-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);margin-bottom:2px}
.econ-val{font-size:30px;font-weight:900;letter-spacing:-2px;color:var(--green)}
.econ-val.red{color:var(--red)}
.econ-period{font-size:11px;color:var(--muted)}

.grid{
  display:grid;
  grid-template-columns:320px 1fr;
  gap:16px;
  align-items:start;
}

.left-column,
.right-column{
  display:flex;
  flex-direction:column;
  gap:14px;
}

.full{
  grid-column:auto;
}

.scard-body{
  padding:10px 12px;
}

.alg-strip{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:8px;
}

.topbar-pdf{
  height:34px;
  padding:0 14px;
  border:none;
  border-radius:18px;
  background:var(--green);
  color:#fff;
  font-family:inherit;
  font-size:11px;
  font-weight:700;
  cursor:pointer;
  display:flex;
  align-items:center;
  gap:6px;
  transition:.2s;
}

.topbar-pdf:hover{
  opacity:.85;
}

@media(max-width:900px){
  .grid{
    grid-template-columns:1fr;
  }
}

/* ── SCARD ── */
.scard{background:var(--s1);border:1px solid var(--bd);border-radius:12px;overflow:hidden;box-shadow:var(--shadow);transition:background .25s,border-color .25s}
.scard-header{padding:12px 18px;border-bottom:1px solid var(--bd);display:flex;align-items:center;gap:8px;background:var(--s2)}
.scard-header-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;background:var(--green-bg);border:1px solid var(--green-bd);flex-shrink:0}
.scard-header-title{font-size:12px;font-weight:700;color:var(--text);flex:1}
.scard-header-sub{font-size:11px;color:var(--muted)}
.scard-body{padding:10px 12px;}

/* ── FIELDS ── */
.frow{display:grid;grid-template-columns:1fr 130px;align-items:center;gap:10px;margin-bottom:10px}
.frow:last-child{margin-bottom:0}
.frow-label{font-size:12px;font-weight:500;color:var(--muted);display:flex;align-items:center;gap:5px}
.tip{width:15px;height:15px;border-radius:50%;background:var(--s3);border:1px solid var(--bd2);display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:var(--muted2);cursor:help;position:relative;flex-shrink:0}
.tip:hover::after{content:attr(data-tip);position:absolute;left:20px;top:-4px;background:var(--tip-bg);border:1px solid var(--tip-bd);border-radius:7px;padding:6px 10px;font-size:11px;font-weight:400;color:var(--text);z-index:300;box-shadow:var(--shadow);min-width:180px;max-width:260px;white-space:normal;line-height:1.4}
.input-wrap{display:flex;align-items:center;background:var(--input-bg);border:1px solid var(--bd2);border-radius:8px;overflow:hidden;transition:border-color .2s,background .25s}
.input-wrap:focus-within{border-color:var(--green)}
.input-wrap input,.input-wrap select{background:transparent;border:none;outline:none;padding:7px 10px;color:var(--text);font-family:inherit;font-size:12px;font-weight:500;width:100%;min-width:0}
.input-unit{padding:0 10px 0 4px;font-size:11px;font-weight:600;color:var(--muted2);white-space:nowrap;flex-shrink:0}
select option{background:var(--s2);color:var(--text)}

.mini-chips{display:grid;gap:8px;margin-top:8px}
.mini-chips.cols2{grid-template-columns:1fr 1fr}
.mini-chips.cols3{grid-template-columns:1fr 1fr 1fr}
.chip{background:var(--s2);border:1px solid var(--bd);border-radius:8px;padding:8px 10px;text-align:center;transition:background .25s,border-color .25s}
.chip-label{font-size:10px;color:var(--muted);margin-bottom:2px}
.chip-val{font-size:13px;font-weight:700;color:var(--text)}
.chip-val.red{color:var(--red)}
.chip-val.green{color:var(--green)}

.subtotal-row{background:var(--green-bg);border:1px solid var(--green-bd);border-radius:8px;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;margin-top:8px}
.subtotal-row label{font-size:11px;color:var(--muted);font-weight:500}
.subtotal-row strong{font-size:13px;font-weight:800;color:var(--green)}

/* ── COMPARATIVO ── */
.comp-grid{display:grid;grid-template-columns:1fr 50px 1fr}
.comp-side{padding:18px}
.comp-vs-col{display:flex;align-items:center;justify-content:center;border-left:1px solid var(--bd);border-right:1px solid var(--bd)}
.vs-badge{width:38px;height:38px;border-radius:50%;border:2px solid var(--bd2);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--muted)}
.comp-side-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.cstt-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.metric{margin-bottom:14px}
.metric-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;gap:8px}
.metric-name{font-size:12px;font-weight:500;color:var(--muted)}
.metric-name small{display:block;font-size:10px;color:var(--muted2);margin-top:1px}
.metric-val{font-size:13px;font-weight:700;color:var(--text);white-space:nowrap}
.metric-val.neg{color:var(--red)}
.track{height:8px;background:var(--s3);border-radius:4px;overflow:hidden}
.fill{height:100%;border-radius:4px;background:var(--green);transition:width .4s cubic-bezier(.4,0,.2,1);min-width:4px}
.fill.neg{background:var(--red)}
.comp-div{height:1px;background:var(--bd);margin:14px 0}
.comp-total{background:var(--bg);border:1px solid var(--bd2);border-radius:10px;padding:14px;margin-top:16px;transition:all .25s}
.comp-total.winner-block{background:var(--green-bg);border-color:var(--green-bd)}
.ct-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:10px}
.ct-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px}
.ct-row:last-child{margin-bottom:0}
.ct-lbl{font-size:12px;color:var(--muted)}
.ct-val{font-size:13px;font-weight:700;color:var(--green)}
.ct-val.big{font-size:24px;font-weight:900;letter-spacing:-1.5px}

/* ── ALUGUEL ── */
.alg-strip{
  display:grid;
  grid-template-columns:1fr 1fr 1fr;
  gap:8px;
}
.alg-col-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:10px}
.list-item{display:flex;justify-content:space-between;align-items:center;padding:8px 12px;background:var(--s2);border-radius:8px;border:1px solid var(--bd);margin-bottom:6px}
.list-item span{font-size:12px;color:var(--muted)}
.list-item strong{font-size:12px;font-weight:700;color:var(--text)}
.list-item strong.green{color:var(--green)}

/* ── WARNING ── */
.warning-box{background:#1E1000;border:1px solid #4A3000;border-radius:8px;padding:8px 12px;font-size:11px;color:#C4902A;margin-top:8px;display:none}
[data-theme="light"] .warning-box{background:#FFF8EC;border-color:#E8C060;color:#8A5A00}

/* ── MEMÓRIA ── */
.mem-toggle{display:flex;align-items:center;gap:8px;padding:12px 18px;cursor:pointer;border-top:1px solid var(--bd);background:var(--s2);font-size:11px;font-weight:600;color:var(--muted);user-select:none}
.mem-toggle:hover{color:var(--text)}
.mem-arrow{transition:transform .2s;font-size:10px;margin-left:auto}
.mem-dots{display:flex;gap:5px}
.mem-dot{width:10px;height:10px;border-radius:50%}
.mem-body{padding:16px 18px;font-family:'Fira Code','SF Mono',Consolas,monospace;font-size:11.5px;color:#6FD98A;white-space:pre-wrap;line-height:1.65;background:#050A06;display:none}
[data-theme="light"] .mem-body{background:#F0F8F2;color:#1A6B30}
.mem-body.open{display:block}

/* ── PDF BUTTON ── */
.pdf-btn{display:inline-flex;align-items:center;gap:7px;background:var(--green);color:#fff;font-family:inherit;font-size:12px;font-weight:700;border:none;border-radius:8px;padding:8px 18px;cursor:pointer;transition:opacity .2s;margin:12px 18px 14px}
.pdf-btn:hover{opacity:.85}
[data-theme="light"] .pdf-btn{color:#003D18}

/* ── GLOSSÁRIO ── */
.gloss-page{padding:24px}
.gloss-intro{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.7;max-width:780px}
.gloss-section{margin-bottom:32px}
.gloss-section-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;color:var(--green);margin-bottom:14px;display:flex;align-items:center;gap:8px}
.gloss-section-title::after{content:'';flex:1;height:1px;background:var(--bd2)}
.gloss-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:12px}
.gloss-card{background:var(--s1);border:1px solid var(--bd);border-radius:10px;padding:14px 16px;box-shadow:var(--shadow);transition:border-color .2s,background .25s}
.gloss-card:hover{border-color:var(--green-bd)}
.gloss-card-header{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.gloss-card-icon{font-size:18px;flex-shrink:0}
.gloss-card-term{font-size:13px;font-weight:700;color:var(--text)}
.gloss-card-tag{font-size:10px;font-weight:600;color:var(--green);background:var(--green-bg);border:1px solid var(--green-bd);border-radius:10px;padding:2px 8px;margin-left:auto;white-space:nowrap}
.gloss-card-def{font-size:12px;color:var(--muted);line-height:1.65}
.gloss-card-formula{margin-top:8px;background:var(--s2);border-left:3px solid var(--green-bd);border-radius:0 6px 6px 0;padding:6px 10px;font-family:'Fira Code',Consolas,monospace;font-size:11px;color:var(--green);line-height:1.6}
[data-theme="light"] .gloss-card-formula{color:#006B20}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:2px}

@media(max-width:900px){
  .result-hero,.grid,.alg-strip,.comp-grid,.gloss-grid{grid-template-columns:1fr}
  .comp-vs-col{display:none}
}

/* ── PRINT / PDF ── */
@media print{
  body{background:#fff!important;color:#000!important;font-size:12pt}
  .topbar,.tabs-bar,.pdf-btn,.mem-toggle{display:none!important}
  .mem-body{display:block!important;background:#f8f8f8!important;color:#1A4A28!important;border:1px solid #ccc!important;padding:16px!important;border-radius:6px!important}
  .print-only{display:block!important}
  *{box-shadow:none!important;transition:none!important}
}
.print-only{display:none}
</style>
</head>
<body>

<!-- TOPBAR -->
<header class="topbar">
  <div class="logo">
    <div class="logo-mark">L&</div>
    <div>
      <div class="logo-name">Localiza<em>&amp;Co</em></div>
      <div class="logo-sub">Simulador de Frota</div>
    </div>
  </div>
  <div class="topbar-right">
    <div class="profile-switcher">
      <button class="p-btn" id="btnPresumido" data-profile="presumido" type="button">Lucro Presumido</button>
      <button class="p-btn active" id="btnReal" data-profile="real" type="button">Lucro Real</button>
    </div>

    <button class="topbar-pdf" onclick="exportPDF()">
      📄 Exportar PDF
    </button>

    <div class="theme-toggle" id="themeToggle" title="Alternar tema">
      <div class="tt-knob" id="ttKnob">🌙</div>
    </div>
  </div>
</header>

<!-- TABS -->
<div class="tabs-bar">
  <button class="tab active" id="tabSim" onclick="switchTab('sim')">📊 Simulador</button>
  <button class="tab" id="tabGloss" onclick="switchTab('gloss')">📖 Glossário</button>
</div>

<!-- ═══════════ TAB: SIMULADOR ═══════════ -->
<div class="tab-panel active" id="panelSim">
<div class="page">

  <div class="result-hero">
    <div class="rh-card loser" id="cardFrota">
      <div>
        <div class="rh-badge" id="badgeFrota">🚗 Frota Própria</div>
        <div class="rh-title">Custo efetivo anual</div>
        <div class="rh-value" id="kpiFrota">R$ 0</div>
        <div class="rh-sub" id="kpiFrotaSub">custo efetivo anual</div>
      </div>
      <div class="rh-right">
        <div class="rh-mes-label">por mês</div>
        <div class="rh-mes" id="kpiFrotaMes">R$ 0</div>
      </div>
    </div>
    <div class="rh-card loser" id="cardAluguel">
      <div>
        <div class="rh-badge" id="badgeAluguel">🔑 Aluguel</div>
        <div class="rh-title">Custo efetivo anual</div>
        <div class="rh-value" id="kpiAluguel">R$ 0</div>
        <div class="rh-sub" id="kpiAluguelSub">custo efetivo anual</div>
      </div>
      <div class="rh-right">
        <div class="rh-mes-label">por mês</div>
        <div class="rh-mes" id="kpiAluguelMes">R$ 0</div>
      </div>
    </div>

    <div class="rh-card loser" id="cardEconomia">
      <div>
        <div class="rh-badge" id="badgeEconomia">💰 Diferença</div>
        <div class="rh-title" id="kpiEconomiaTitle">Diferença anual</div>
        <div class="rh-value" id="kpiEconomia">R$ 0</div>
        <div class="rh-sub" id="kpiEconomiaSub">economia estimada</div>
      </div>
    </div>

  </div>

  

  <div class="econ-banner" id="econBanner">
    <div class="econ-icon" id="econIcon">💡</div>
    <div class="econ-body">
      <div class="econ-title" id="econTitle">Analisando...</div>
      <div class="econ-list" id="econList">—</div>
    </div>
    <div class="econ-value-block">
      <div class="econ-val-label">Economia estimada</div>
      <div class="econ-val" id="econVal">R$ 0</div>
      <div class="econ-period" id="econPeriod">por ano</div>
    </div>
  </div>

  <div class="grid">

    <!-- COLUNA ESQUERDA: FROTA PRÓPRIA -->
    <div class="left-column">
  
      <div class="scard">
        <div class="scard-header">
          <div class="scard-header-icon">🚗</div>
          <div>
            <div class="scard-header-title">Aquisição do Veículo</div>
            <div class="scard-header-sub">Preço, desconto e entrada</div>
          </div>
        </div>
  
